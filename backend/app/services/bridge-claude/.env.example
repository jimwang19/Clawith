# Clawith Bridge-Claude Configuration

# ── Clawith Gateway ───────────────────────────────────────────────────────────
CLAWITH_API_URL=http://localhost:8000
CLAWITH_API_KEY=oc-your-api-key-here

# ── Claude Code Settings ──────────────────────────────────────────────────────
# Base directory for per-conversation workdirs: {CLAUDE_WORKDIR_BASE}/{conversation_id}
CLAUDE_WORKDIR_BASE=/workspaces

# Optional: pin a specific Claude model ID (leave empty for default)
CLAUDE_MODEL=

# Maximum conversation turns per task
CLAUDE_MAX_TURNS=50

# Permission mode: default | acceptEdits | bypassPermissions
# - default: Bash/Write/Edit require user confirmation via Clawith
# - acceptEdits: file edits auto-accepted, other ops may still require confirmation
# - bypassPermissions: skip all confirmations (use only in trusted environments)
CLAUDE_PERMISSION_MODE=default

# Comma-separated list of allowed tools (leave empty to allow all)
# Example: CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep,Bash
CLAUDE_ALLOWED_TOOLS=

# ── Polling & Timeouts ────────────────────────────────────────────────────────
# How often to poll Clawith for new messages (seconds)
POLL_INTERVAL=5

# Max seconds to wait for Claude to finish a task before reporting timeout
TASK_TIMEOUT=300

# HTTP timeout per request (seconds)
HTTP_TIMEOUT_SECONDS=10

# Retry settings for transient network errors
HTTP_MAX_RETRIES=2
HTTP_RETRY_BASE_DELAY=0.7
HTTP_RETRY_MAX_DELAY=5
HTTP_RETRY_JITTER=0.25

# Emit warning after N consecutive HTTP failures
HTTP_ALERT_CONSEC_FAILS=5

# ── Progress Updates ──────────────────────────────────────────────────────────
# Set to 1 to send intermediate status messages to Clawith (requires send API)
CLAWITH_SEND_ENABLED=0

# Log a "still idle" message every N poll cycles (0 = disable)
IDLE_POLL_LOG_EVERY=12

# For agent-to-agent conversations: send progress via report endpoint (1=yes)
PROGRESS_VIA_REPORT=1

# ── Recovery ──────────────────────────────────────────────────────────────────
# Max age (seconds) of inflight tasks to recover on restart
INFLIGHT_RECOVER_MAX_AGE=900

# ── Concurrency Control ───────────────────────────────────────────────────────
# Maximum simultaneous Claude tasks; excess requests receive a 429 rejection
MAX_CONCURRENT_TASKS=2

# ── Status HTTP Server ────────────────────────────────────────────────────────
# Local port for the status/control sidecar server
#   GET  /status                  — list active tasks
#   GET  /status/{msg_id}         — single-task detail
#   POST /session/{conv_id}/decide — inject allow/deny permission decision
BRIDGE_STATUS_PORT=8765

# ── Test / E2E helpers (test_e2e_bridge.py) ───────────────────────────────────
# Name of this bridge agent as registered in Clawith (used for gateway self-send injection)
# BRIDGE_AGENT_NAME=cc-agent

# PostgreSQL connection string for direct DB injection (T05 concurrency test requires this)
# Strip +asyncpg suffix if copying from backend DATABASE_URL
# CLAWITH_DB_URL=postgresql://clawith:clawith@localhost:5432/clawith
